      "item": [
        { "name": "AutoFix generate (XSS)", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/autofix/generate", "header": [{"key": "Content-Type", "value": "application/json"}], "body": { "mode": "raw", "raw": "{\"finding_id\": \"rw-xss\", \"finding_type\": \"xss\", \"language\": \"javascript\", \"code_context\": \"document.innerHTML = userInput;\"}" } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "AutoFix stats", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/autofix/stats" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Fix types", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/autofix/fix-types" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Remediation backlog", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/remediation/backlog" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
