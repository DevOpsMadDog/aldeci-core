{
  "info": {
    "name": "ALdeci CTEM+ — Real-World 7-Phase Trial (Zero Hardcoding)",
    "description": "Enterprise client deployment validation.\nMaps to ORG_WIDE_PERSONA_TRIAL_RUNBOOK.md phases.\n\nRun:\n  newman run ALdeci-Real-World-7Phase.postman_collection.json \\\n    --env-var 'baseUrl=https://client-aldeci.example.com' \\\n    --env-var 'apiKey=CLIENT_API_KEY' \\\n    --env-var 'orgId=client-org' \\\n    --reporters cli,htmlextra",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "X-API-Key", "type": "string" },
      { "key": "value", "value": "{{apiKey}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "" },
    { "key": "apiKey", "value": "" },
    { "key": "orgId", "value": "default" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "if (!pm.variables.get('baseUrl')) { throw new Error('baseUrl not set — pass --env-var baseUrl=...'); }",
          "if (!pm.variables.get('apiKey')) { throw new Error('apiKey not set — pass --env-var apiKey=...'); }"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Response time < 5000ms', () => pm.expect(pm.response.responseTime).to.be.below(5000));",
          "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
          "pm.test('Response body is valid JSON', () => { pm.response.json(); });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Phase 0 — Health Gate",
      "item": [
        { "name": "Deployment health", "request": { "method": "GET", "url": "{{baseUrl}}/health" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "System info", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/system/info" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has system data', () => pm.expect(pm.response.json()).to.be.an('object'));"] } }] },
        { "name": "System health", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/system/health" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Version", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/version" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Metrics", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/metrics" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] }
      ]
    },
    {
      "name": "Phase 1 — Intake & Scope Lock",
      "item": [
        { "name": "List applications", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/inventory/applications" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "List assets", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/inventory/assets" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Policies", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/policies" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Teams", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/teams" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Knowledge Graph status", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/knowledge-graph/status" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Code-to-Cloud status", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/code-to-cloud/status" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] }
      ]
