        { "name": "Ingest stats", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/scanner-ingest/stats" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Dedup clusters", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/deduplication/clusters?org_id={{orgId}}" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Dedup stats", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/deduplication/stats" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "NVD recent", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/feeds/nvd/recent" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "EPSS scores", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/feeds/epss/scores" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Feeds status", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/feeds/status" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Nerve center pulse", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/nerve-center/pulse" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Copilot ask", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/copilot/ask", "header": [{"key": "Content-Type", "value": "application/json"}], "body": { "mode": "raw", "raw": "{\"question\": \"What findings need attention?\"}" } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] }
      ]
    },
    {
      "name": "Phase 3 — Prioritize & Decide",
      "item": [
        { "name": "FAIL score CVE", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/fail/score", "header": [{"key": "Content-Type", "value": "application/json"}], "body": { "mode": "raw", "raw": "{\"cve_id\": \"CVE-2021-44228\", \"cvss\": 10.0, \"epss\": 0.975, \"is_kev\": true}" } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "FAIL top risks", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/fail/top-risks" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Brain stats", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/brain/stats" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Risk velocity", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/analytics/risk-velocity" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Coverage analysis", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/analytics/coverage" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Noise reduction", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/analytics/noise-reduction" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "ML status", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/ml/status" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] }
      ]
    },
    {
      "name": "Phase 4 — Validate (MPTE)",
      "item": [
        { "name": "MPTE stats", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/mpte/stats" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Attack sim campaigns", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/attack-sim/campaigns" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "MITRE heatmap", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/attack-sim/mitre/heatmap" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "LLM Guard health", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/llm-guard/health" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Nerve center intelligence map", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/nerve-center/intelligence-map" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] },
        { "name": "Cases", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/cases" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] }
      ]
