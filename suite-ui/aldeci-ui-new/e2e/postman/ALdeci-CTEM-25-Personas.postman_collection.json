        { "name": "Check compliance posture", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/compliance-engine/soc2/status" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has compliance data', () => { const d = pm.response.json(); pm.expect(d).to.be.an('object'); });"] } }] },
