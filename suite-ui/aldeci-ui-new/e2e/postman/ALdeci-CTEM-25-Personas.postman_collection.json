{
  "info": {
    "name": "ALdeci CTEM+ — 25 Persona API Validation (Enterprise)",
    "description": "Enterprise persona-based API contract validation for ALdeci CTEM+ platform.\n\nCovers all 25 personas with real-world workflow endpoints.\nEach request validates: status code, response time (<5s), content-type, and response body schema.\n\nRun:\n  newman run ALdeci-CTEM-25-Personas.postman_collection.json \\\n    --env-var 'baseUrl=http://localhost:8000' \\\n    --env-var 'apiKey=YOUR_KEY' \\\n    --reporters cli,htmlextra \\\n    --reporter-htmlextra-export reports/newman-report.html",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "X-API-Key", "type": "string" },
      { "key": "value", "value": "{{apiKey}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "apiKey", "value": "" }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "// Global assertions for every request",
          "pm.test('Response time < 5000ms', () => pm.expect(pm.response.responseTime).to.be.below(5000));",
          "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
          "pm.test('Response body is valid JSON', () => { pm.response.json(); });"
        ]
      }
    }
  ],
  "item": [
