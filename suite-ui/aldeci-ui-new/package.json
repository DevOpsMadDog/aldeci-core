{
  "name": "aldeci-ui-new",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "e2e": "playwright test",
    "e2e:golden": "playwright test e2e/golden-paths.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:personas": "playwright test e2e/persona-api-workflows.spec.ts e2e/persona-rbac-enforcement.spec.ts e2e/persona-cross-role-workflows.spec.ts",
    "test:e2e:allure": "playwright test && npx allure generate allure-results --clean -o allure-report && npx allure open allure-report",
    "test:e2e:allure:generate": "npx allure generate allure-results --clean -o allure-report",
    "test:e2e:allure:open": "npx allure open allure-report",
    "test:e2e:newman": "bash e2e/run-newman.sh",
    "test:e2e:newman:ci": "npx newman run e2e/postman/ALdeci-CTEM-25-Personas.postman_collection.json --reporters cli,htmlextra --reporter-htmlextra-export newman-reports/newman-report.html --delay-request 100 --timeout-request 10000",
    "test:e2e:full": "npm run test:e2e && npm run test:e2e:newman",
    "test:e2e:5space": "playwright test e2e/ctem-5-space-ui.spec.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.0"
  },
  "overrides": {
    "dompurify": "^3.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "allure-playwright": "^3.6.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
