        "description": {
          "description_data": [
            {"lang": "en", "value": "Apache Log4j2 <= 2.14.1 JNDI features used in configuration, log messages, and parameters do not protect against attacker controlled LDAP and other JNDI related endpoints. An attacker who can control log messages or log message parameters can execute arbitrary code loaded from LDAP servers when message lookup substitution is enabled."}
          ]
        },
        "references": {
          "reference_data": [
