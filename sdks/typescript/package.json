{
  "name": "@aldeci/client",
  "version": "1.0.0",
  "description": "Typed TypeScript/JavaScript client for the ALDECI Security Intelligence Platform API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "build:types": "tsc --project tsconfig.build.json --declaration --emitDeclarationOnly",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "aldeci",
    "security",
    "aspm",
    "ctem",
    "cspm",
    "api-client",
    "typescript"
  ],
  "author": "FixOps <info@devopsai.co>",
  "license": "MIT",
  "homepage": "https://github.com/DevOpsMadDog/Fixops",
  "repository": {
    "type": "git",
    "url": "https://github.com/DevOpsMadDog/Fixops.git",
    "directory": "sdks/typescript"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
