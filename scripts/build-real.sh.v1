#!/opt/homebrew/bin/bash
###############################################################################
# ALdeci BUILD-REAL — No-Fluff Task Runner
#
# This script gives Claude agents SPECIFIC coding tasks.
# No debates. No grading loops. No status files. Just BUILD.
#
# Usage:
#   ./scripts/build-real.sh                  # Run all tasks sequentially
#   ./scripts/build-real.sh --task <number>  # Run specific task
#   ./scripts/build-real.sh --list           # List all tasks
#   ./scripts/build-real.sh --dry-run        # Show what would run
###############################################################################
set -uo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$PROJECT_ROOT"

LOG_DIR="$PROJECT_ROOT/logs/build-real"
mkdir -p "$LOG_DIR"

TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
MAX_TURNS=50
TIMEOUT=900  # 15 min per task

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BOLD='\033[1m'; NC='\033[0m'

# Find timeout command
TIMEOUT_CMD=""
command -v gtimeout &>/dev/null && TIMEOUT_CMD="gtimeout"
command -v timeout &>/dev/null && TIMEOUT_CMD="${TIMEOUT_CMD:-timeout}"

# Unset nested session vars
unset CLAUDECODE CLAUDE_CODE_ENTRYPOINT 2>/dev/null || true

###############################################################################
# TASK DEFINITIONS — Each task is ONE specific coding deliverable
###############################################################################

TASK_NAMES=()
TASK_PROMPTS=()
TASK_TIMEOUTS=()

# ─── TASK 1: Fix quantum crypto verify ───────────────────────────────────────
TASK_NAMES+=("fix-quantum-verify")
TASK_TIMEOUTS+=(900)
TASK_PROMPTS+=("FIX: Quantum Crypto Verification Returns True For Everything

FILE: suite-core/core/quantum_crypto.py

PROBLEM: The _verify_simplified() method at ~line 258 returns True for ANY signature
that has the correct length. This means evidence signatures have ZERO security value.

TASK:
1. Read suite-core/core/quantum_crypto.py fully
2. Fix _verify_simplified() to actually verify signatures:
   - When signing in simplified mode, use HMAC-SHA256 with the private key material
   - Store the HMAC as the signature
   - In verify, recompute HMAC with the public key (derive shared material) and compare
   - If you cannot do proper ML-DSA without the library, at MINIMUM do HMAC-SHA256
     verification that actually rejects invalid signatures
3. Run: python -m pytest tests/ -k quantum -v --timeout=10
4. If no quantum tests exist, create tests/test_quantum_crypto.py with:
   - test_sign_verify_roundtrip (sign then verify = True)
   - test_verify_rejects_tampered_signature (modify 1 byte = False)
   - test_verify_rejects_wrong_message (different message = False)
   - test_verify_rejects_random_bytes (random signature = False)

DONE WHEN: _verify_simplified() returns False for invalid signatures and tests pass.")

# ─── TASK 2: Fix MindsDB commented-out connection ────────────────────────────
TASK_NAMES+=("fix-mindsdb-stub")
TASK_TIMEOUTS+=(900)
TASK_PROMPTS+=("FIX: MindsDB Agent Has Commented-Out Connection

FILE: suite-core/agents/mindsdb_agents.py

PROBLEM: Line ~97 has: # self._mindsdb_client = await self._connect_mindsdb()
Then line ~98 sets self._initialized = True without connecting. This makes the
entire 1,024 LOC file a dead stub.

TASK:
1. Read suite-core/agents/mindsdb_agents.py fully
2. Uncomment the connection line
3. Add proper error handling: if mindsdb_sdk is not installed, log a clear warning
   and set self._initialized = False (not True)
4. Add a health_check endpoint that returns honest status:
   - mindsdb_sdk installed? yes/no
   - connection established? yes/no
   - If not installed: return {status: 'unavailable', reason: 'mindsdb_sdk not installed'}
5. Find ALL places where self._initialized is set to True without actual work — fix them
6. Run: python -c 'from agents.mindsdb_agents import *; print(\"import OK\")'
7. Run any existing tests: python -m pytest tests/ -k mindsdb -v --timeout=10

DONE WHEN: MindsDB agent honestly reports its status and doesn't pretend to be connected.")

# ─── TASK 3: Fix EvidenceBundles demo data fallback ──────────────────────────
TASK_NAMES+=("fix-evidence-demo-data")
TASK_TIMEOUTS+=(900)
TASK_PROMPTS+=("FIX: EvidenceBundles.tsx Silently Falls Back to Fake Data

FILE: suite-ui/aldeci/src/pages/evidence/EvidenceBundles.tsx

PROBLEM: This 2,092 LOC page calls real APIs but catches errors and silently loads
DEMO_BUNDLES (~100 lines of hardcoded fake data around line 1623) and DEMO_COMPLIANCE
(~line 1638). Users see fake data without knowing it.

TASK:
1. Read suite-ui/aldeci/src/pages/evidence/EvidenceBundles.tsx fully
2. Find DEMO_BUNDLES and DEMO_COMPLIANCE constants — DELETE them entirely
3. In the catch blocks where they were used, replace with proper error handling:
   - Set an error state variable
   - Show an error banner: 'Failed to load evidence bundles. Backend may be offline.'
   - Show a Retry button that re-fetches
   - Do NOT show fake data
4. Verify the fix compiles: cd suite-ui/aldeci && npx tsc --noEmit 2>&1 | head -20

DONE WHEN: No DEMO_BUNDLES or DEMO_COMPLIANCE exist in the file. Error states show
a clear message instead of fake data.")

# ─── TASK 4: Make FalkorDB backend persistent ────────────────────────────────
TASK_NAMES+=("fix-falkordb-persistence")
TASK_TIMEOUTS+=(900)
TASK_PROMPTS+=("FIX: Knowledge Graph Data Lost on Every Restart

FILE: suite-core/core/falkordb_client.py

PROBLEM: The NetworkXGraphBackend (fallback used when falkordb is not installed)
stores all graph data in Python dicts. Everything is lost when the server restarts.
The falkordb pip package IS now installed but needs a FalkorDB server to connect to.

TASK:
1. Read suite-core/core/falkordb_client.py fully
2. Make the NetworkXGraphBackend persistent by:
   - On every write operation (add_node, add_edge, update_node, delete), 
     serialize the NetworkX graph to a JSON file at data/knowledge_graph.json
   - On initialization, load from that file if it exists
   - Use a debounced save (save at most every 5 seconds to avoid I/O thrashing)
   - Use atomic writes (write to .tmp then rename) to prevent corruption
3. Add a save() and load() method to NetworkXGraphBackend
4. Run: python -c 'from core.falkordb_client import GraphClient; g = GraphClient(); print(f\"Backend: {g.backend_name}\"); g.add_node(\"test-1\", \"finding\", {\"title\": \"test\"}); g.save(); print(\"Saved OK\")'
5. Run: python -m pytest tests/ -k 'graph\|falkor\|knowledge' -v --timeout=10

DONE WHEN: Graph data survives a Python process restart using the file-based persistence.")

# ─── TASK 5: Add missing deps to requirements.txt ────────────────────────────
TASK_NAMES+=("fix-requirements")
TASK_TIMEOUTS+=(600)
TASK_PROMPTS+=("FIX: requirements.txt Missing Critical Dependencies

FILE: requirements.txt

PROBLEM: Several dependencies referenced in code are not in requirements.txt:
- datasketch (used in zero_gravity.py for MinHash dedup)
- river (referenced in vision for streaming ML, code may reference it)

TASK:
1. Read requirements.txt
2. Search the entire codebase for import statements of packages NOT in requirements.txt:
   grep -r 'import datasketch\|from datasketch\|import river\|from river\|import dilithium\|from dilithium\|import oqs\|from oqs\|import mindsdb_sdk\|from mindsdb_sdk' suite-core/ suite-attack/ suite-integrations/ suite-feeds/ suite-evidence-risk/ 2>/dev/null
3. For each found import that's inside a try/except (optional dependency):
   - Add it to requirements.txt with a comment # optional: <why>
4. For each found import that's NOT in try/except (required):
   - Add it to requirements.txt
5. Verify: pip install -r requirements.txt 2>&1 | tail -5

DONE WHEN: All imports in the codebase have matching entries in requirements.txt.")

# ─── TASK 6: Wire self-learning feedback to actual model improvement ─────────
TASK_NAMES+=("fix-self-learning")
TASK_TIMEOUTS+=(900)
TASK_PROMPTS+=("IMPROVE: Self-Learning Feedback Actually Adjusts Scoring

FILE: suite-core/core/self_learning.py

PROBLEM: The 5 feedback loops collect data into SQLite but the weight adjustments
don't actually feed back into the brain_pipeline scoring. The learning is isolated.

TASK:
1. Read suite-core/core/self_learning.py fully
2. Read suite-core/core/brain_pipeline.py — find where risk scoring happens (Step 7)
3. Wire the self-learning weights into the scoring step:
   - When brain_pipeline scores a finding, check if self_learning has weight
     adjustments for that scanner/rule combination
   - Apply the adjustment as a multiplier (e.g., if FP rate for scanner X rule Y
     is 80%, reduce the score by 0.2x)
4. Add a method get_scoring_adjustment(scanner: str, rule_id: str) -> float to
   SelfLearningEngine that returns a multiplier between 0.1 and 2.0
5. Call this from brain_pipeline Step 7
6. Run: python -m pytest tests/test_brain_pipeline.py tests/test_self_learning.py -v --timeout=10

DONE WHEN: Brain pipeline scoring uses self-learning feedback data.")

# ─── TASK 7: Create 3 real test files for scanners ───────────────────────────
TASK_NAMES+=("add-scanner-tests")
TASK_TIMEOUTS+=(900)
TASK_PROMPTS+=("BUILD: Real Tests for Native Scanners

PROBLEM: The 8 native scanners have ~5,200 LOC but limited test coverage.

TASK: Create 3 test files with meaningful tests:

1. tests/test_sast_engine.py:
   - test_scan_sql_injection: scan a Python string with 'cursor.execute(f\"SELECT * FROM users WHERE id={user_input}\")' — should find SQLi
   - test_scan_clean_code: scan safe code — should find 0 vulnerabilities
   - test_scan_xss: scan JS with innerHTML assignment — should find XSS
   - test_scan_hardcoded_secret: scan code with 'password = \"admin123\"' — should detect
   - test_owasp_category_mapping: verify every finding has a valid OWASP category

2. tests/test_dast_engine.py:
   - test_ssrf_protection: verify scanner blocks RFC1918 IPs, loopback, metadata endpoints
   - test_link_parser: feed HTML with links and forms, verify extraction
   - test_security_header_check: mock an HTTP response missing headers, verify detection

3. tests/test_container_scanner.py:
   - test_dockerfile_root_user: scan 'FROM ubuntu\nRUN apt-get update' (no USER) — should flag
   - test_dockerfile_latest_tag: scan 'FROM nginx:latest' — should flag
   - test_dockerfile_good: scan a Dockerfile with USER, specific tag, HEALTHCHECK — should pass

Import the REAL engine classes. Use pytest. Each test must assert specific findings.
Run: python -m pytest tests/test_sast_engine.py tests/test_dast_engine.py tests/test_container_scanner.py -v --timeout=10

DONE WHEN: All 3 test files exist with 10+ total tests, all passing.")

# ─── TASK 8: Fix MCP to handle tools/call ─────────────────────────────────────
TASK_NAMES+=("fix-mcp-tools-call")
TASK_TIMEOUTS+=(900)
TASK_PROMPTS+=("FIX: MCP Server Cannot Execute Tools

FILES: suite-core/core/mcp_server.py, suite-core/api/mcp_protocol_router.py

PROBLEM: The MCP server has tool auto-discovery (finds all FastAPI endpoints) but
the tools/call endpoint doesn't actually EXECUTE the discovered tools. It's a
registry without execution.

TASK:
1. Read suite-core/core/mcp_server.py fully
2. Read suite-core/api/mcp_protocol_router.py fully
3. Find the tools/call handler — does it actually call the underlying FastAPI endpoint?
4. If not, implement it:
   - When tools/call is received with a tool name and arguments
   - Look up the tool in the registry to get its FastAPI route path and method
   - Use httpx.AsyncClient to call localhost:8000{path} with the arguments
   - Return the response as the tool result
5. Add error handling: tool not found, endpoint error, timeout
6. Run: python -m pytest tests/ -k mcp -v --timeout=10

DONE WHEN: MCP tools/call actually invokes the underlying API endpoint and returns real results.")

###############################################################################
# RUNNER
###############################################################################

TOTAL_TASKS=${#TASK_NAMES[@]}

list_tasks() {
  echo -e "${BOLD}BUILD-REAL Tasks ($TOTAL_TASKS total):${NC}"
  echo ""
  for i in $(seq 0 $((TOTAL_TASKS - 1))); do
    echo -e "  ${GREEN}$((i+1))${NC}. ${TASK_NAMES[$i]}  (timeout: ${TASK_TIMEOUTS[$i]}s)"
  done
  echo ""
  echo "Run all:        ./scripts/build-real.sh"
  echo "Run one:        ./scripts/build-real.sh --task 1"
  echo "Dry run:        ./scripts/build-real.sh --dry-run"
}

run_task() {
  local idx=$1
  local name="${TASK_NAMES[$idx]}"
  local prompt="${TASK_PROMPTS[$idx]}"
  local task_timeout="${TASK_TIMEOUTS[$idx]}"
  local log_file="$LOG_DIR/${TIMESTAMP}_${name}.log"

  echo -e "\n${BOLD}━━━ TASK $((idx+1))/$TOTAL_TASKS: ${name} ━━━${NC}"
  echo -e "${YELLOW}Timeout: ${task_timeout}s | Log: $log_file${NC}"

  if $DRY_RUN; then
    echo -e "${GREEN}[DRY RUN] Would run: $name${NC}"
    echo "$prompt" | head -5
    echo "..."
    return 0
  fi

  local start_time=$(date +%s)

  # Run Claude with the task prompt — no fluff, just the task
  if [[ -n "$TIMEOUT_CMD" ]]; then
    $TIMEOUT_CMD "$task_timeout" claude --print \
      --output-format text \
      --verbose \
      --dangerously-skip-permissions \
      --max-turns "$MAX_TURNS" \
      -p "$prompt" \
      > "$log_file" 2>&1
  else
    claude --print \
      --output-format text \
      --verbose \
      --dangerously-skip-permissions \
      --max-turns "$MAX_TURNS" \
      -p "$prompt" \
      > "$log_file" 2>&1
  fi

  local exit_code=$?
  local end_time=$(date +%s)
  local duration=$(( end_time - start_time ))

  if [[ $exit_code -eq 0 ]]; then
    echo -e "${GREEN}  ✅ ${name} completed in ${duration}s${NC}"
  elif [[ $exit_code -eq 124 ]]; then
    echo -e "${YELLOW}  ⏰ ${name} timed out after ${task_timeout}s${NC}"
  else
    echo -e "${RED}  ❌ ${name} failed (exit: $exit_code) after ${duration}s${NC}"
  fi

  # Show last 5 lines of output
  echo -e "  ${YELLOW}Last output:${NC}"
  tail -5 "$log_file" 2>/dev/null | sed 's/^/    /'

  return $exit_code
}

###############################################################################
# MAIN
###############################################################################

DRY_RUN=false
SINGLE_TASK=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --list)       list_tasks; exit 0 ;;
    --dry-run)    DRY_RUN=true; shift ;;
    --task)       SINGLE_TASK="$2"; shift 2 ;;
    -h|--help)    list_tasks; exit 0 ;;
    *)            echo "Unknown option: $1"; list_tasks; exit 1 ;;
  esac
done

echo -e "${BOLD}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  ALdeci BUILD-REAL — Code, Not Conversations"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "${NC}"
echo "Tasks: $TOTAL_TASKS | Timeout: ${TIMEOUT}s each | Model: claude"
echo "Logs: $LOG_DIR/"
echo ""

OVERALL_START=$(date +%s)
PASSED=0
FAILED=0

if [[ -n "$SINGLE_TASK" ]]; then
  idx=$((SINGLE_TASK - 1))
  if [[ $idx -lt 0 || $idx -ge $TOTAL_TASKS ]]; then
    echo -e "${RED}Invalid task number: $SINGLE_TASK (valid: 1-$TOTAL_TASKS)${NC}"
    exit 1
  fi
  run_task "$idx" && PASSED=$((PASSED+1)) || FAILED=$((FAILED+1))
else
  for i in $(seq 0 $((TOTAL_TASKS - 1))); do
    run_task "$i" && PASSED=$((PASSED+1)) || FAILED=$((FAILED+1))
  done
fi

OVERALL_END=$(date +%s)
OVERALL_DURATION=$(( OVERALL_END - OVERALL_START ))

echo ""
echo -e "${BOLD}━━━ BUILD-REAL SUMMARY ━━━${NC}"
echo -e "  ${GREEN}Passed: $PASSED${NC}  ${RED}Failed: $FAILED${NC}  Duration: ${OVERALL_DURATION}s"
echo ""

###############################################################################
# POST-RUN: Update Team Memory (so future agents know what changed)
###############################################################################

if ! $DRY_RUN; then
  echo -e "${BOLD}Updating team memory...${NC}"
  STATE_DIR="$PROJECT_ROOT/.claude/team-state"
  RUN_DATE=$(date +"%Y-%m-%d %H:%M")
  RUN_DATE_SHORT=$(date +"%Y-%m-%d")

  # ── 1. Append to decisions.log ──────────────────────────────────────────────
  {
    echo ""
    echo "[$RUN_DATE] agent:build-real DECISION: Execute $TOTAL_TASKS focused build tasks (no-fluff mode)"
    echo "  CONTEXT: CEO directed AI team to produce code instead of status reports. build-real.sh replaced 7,518-line swarm."
    echo "  ACTION: Ran $TOTAL_TASKS tasks — $PASSED passed, $FAILED failed (${OVERALL_DURATION}s total)"

    # List each task result
    for i in $(seq 0 $((TOTAL_TASKS - 1))); do
      local_name="${TASK_NAMES[$i]}"
      local_log="$LOG_DIR/${TIMESTAMP}_${local_name}.log"
      if [[ -f "$local_log" ]]; then
        # Check if task produced file changes
        local_changes=$(grep -c 'Created\|Modified\|Updated\|wrote\|created file\|edit_file\|create_file' "$local_log" 2>/dev/null || echo "0")
        echo "    - $local_name: ${local_changes} file operations detected"
      fi
    done

    echo "  RESULT: $PASSED/$TOTAL_TASKS tasks completed successfully"
    echo "  ROLLBACK: git stash (all changes are uncommitted)"
    echo ""
  } >> "$STATE_DIR/decisions.log"

  # ── 2. Create coordination notes for today ──────────────────────────────────
  COORD_FILE="$STATE_DIR/coordination-notes-build-real-${RUN_DATE_SHORT}.md"
  {
    echo "# ALdeci Build-Real Results — $RUN_DATE_SHORT"
    echo ""
    echo "> **Generated**: ${RUN_DATE} by build-real.sh"
    echo "> **Mode**: No-fluff focused build (8 concrete coding tasks)"
    echo "> **Result**: $PASSED passed, $FAILED failed, ${OVERALL_DURATION}s total"
    echo ""
    echo "## Tasks Executed"
    echo ""
    echo "| # | Task | Status | Duration |"
    echo "|---|------|--------|----------|"

    for i in $(seq 0 $((TOTAL_TASKS - 1))); do
      local_name="${TASK_NAMES[$i]}"
      local_log="$LOG_DIR/${TIMESTAMP}_${local_name}.log"
      if [[ -f "$local_log" ]]; then
        # Extract duration from log filename timing (approximate)
        echo "| $((i+1)) | $local_name | see log | $LOG_DIR/${TIMESTAMP}_${local_name}.log |"
      else
        echo "| $((i+1)) | $local_name | skipped | — |"
      fi
    done

    echo ""
    echo "## Files Changed (git diff)"
    echo ""
    echo '```'
    cd "$PROJECT_ROOT" && git diff --stat 2>/dev/null || echo "(no git repo or no changes)"
    echo '```'
    echo ""
    echo "## What Agents Should Know"
    echo ""
    echo "- quantum_crypto.py: _verify_simplified() should now do HMAC-SHA256 (not return True)"
    echo "- mindsdb_agents.py: honest status reporting, no fake initialized=True"
    echo "- EvidenceBundles.tsx: DEMO_BUNDLES removed, proper error states"
    echo "- falkordb_client.py: NetworkX backend now persists to data/knowledge_graph.json"
    echo "- requirements.txt: missing deps added"
    echo "- self_learning.py: weights now feed into brain_pipeline scoring"
    echo "- New test files: test_sast_engine.py, test_dast_engine.py, test_container_scanner.py"
    echo "- mcp_server.py: tools/call should now execute endpoints"
    echo ""
    echo "## Next Actions"
    echo ""
    echo "- Run full test suite: python -m pytest tests/ --timeout=10 -x -q"
    echo "- Check for regressions in existing tests"
    echo "- git add + commit all changes"
  } > "$COORD_FILE"

  # ── 3. Update sprint-board.json with build-real items ───────────────────────
  # Add a build-real entry to backlog (use Python for safe JSON editing)
  python3 -c "
import json, os, sys
sb_path = '$STATE_DIR/sprint-board.json'
try:
    with open(sb_path) as f:
        sb = json.load(f)
except:
    print('Could not read sprint-board.json, skipping update')
    sys.exit(0)

# Add build-real results as a backlog item
new_item = {
    'id': 'BUILD-REAL-001',
    'title': 'build-real.sh: $PASSED/$TOTAL_TASKS focused coding tasks completed',
    'assignee': 'build-real',
    'status': 'done' if $FAILED == 0 else 'in_progress',
    'points': $TOTAL_TASKS,
    'priority': 'P0',
    'pillar': 'V3',
    'category': 'code-quality',
    'completed_date': '$RUN_DATE_SHORT',
    'acceptance_criteria': [
        'quantum_crypto verify rejects invalid sigs',
        'mindsdb reports honest status',
        'EvidenceBundles shows errors not fake data',
        'FalkorDB persists graph to disk',
        'Scanner tests pass',
        'Self-learning feeds into scoring',
        'MCP tools/call executes endpoints'
    ],
    'progress_notes': '$PASSED passed, $FAILED failed in ${OVERALL_DURATION}s'
}

# Remove old BUILD-REAL entries
sb['backlog'] = [x for x in sb.get('backlog', []) if not x.get('id','').startswith('BUILD-REAL')]
sb['backlog'].append(new_item)

# Update burndown
today_entry = {'day': len(sb.get('burndown',[])) + 1, 'date': '$RUN_DATE_SHORT', 'done': sum(1 for x in sb['backlog'] if x.get('status')=='done'), 'total': len(sb['backlog']), 'note': 'build-real run'}
sb['burndown'].append(today_entry)

with open(sb_path, 'w') as f:
    json.dump(sb, f, indent=2)
print('Sprint board updated')
" 2>&1

  # ── 4. Update CLAUDE.md with today's run ────────────────────────────────────
  # Just append a note to the Known Issues section won't exist — instead create a build-real-status file
  BUILD_STATUS="$STATE_DIR/build-real-status.json"
  python3 -c "
import json
from datetime import datetime
status = {
    'last_run': '$RUN_DATE',
    'tasks_total': $TOTAL_TASKS,
    'tasks_passed': $PASSED,
    'tasks_failed': $FAILED,
    'duration_seconds': $OVERALL_DURATION,
    'log_dir': '$LOG_DIR',
    'timestamp': '$TIMESTAMP',
    'tasks': []
}
task_names = '''${TASK_NAMES[*]}'''.split()
for name in task_names:
    status['tasks'].append({'name': name, 'log': '$LOG_DIR/${TIMESTAMP}_' + name + '.log'})
with open('$BUILD_STATUS', 'w') as f:
    json.dump(status, f, indent=2)
print('Build status saved to $BUILD_STATUS')
" 2>&1

  echo -e "${GREEN}Team memory updated:${NC}"
  echo "  - decisions.log (appended run results)"
  echo "  - $COORD_FILE (coordination notes)"
  echo "  - sprint-board.json (backlog + burndown updated)"
  echo "  - build-real-status.json (machine-readable status)"
  echo ""
fi
